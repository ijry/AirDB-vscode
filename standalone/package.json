{
  "name": "airdb-standalone-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "protocol",
    "vscode-shim",
    "extension-host",
    "app"
  ],
  "scripts": {
    "check:workspace": "node scripts/check-workspace.mjs",
    "test": "npm run test --workspaces --if-present",
