{
  "name": "airdb-standalone-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "protocol",
    "vscode-shim",
    "extension-host",
    "app"
  ],
  "scripts": {
    "check:workspace": "node scripts/check-workspace.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "build:airdb": "node scripts/build-airdb.mjs",
    "prepare:extensions": "node scripts/prepare-extensions.mjs",
    "smoke:tree-ipc": "node scripts/smoke-tree-ipc.mjs",
    "smoke:dialog-ipc": "node scripts/smoke-dialog-ipc.mjs",
    "smoke:file-dialog-ipc": "node scripts/smoke-file-dialog-ipc.mjs",
    "smoke:text-document-ipc": "node scripts/smoke-text-document-ipc.mjs",
    "smoke:external-actions-ipc": "node scripts/smoke-external-actions-ipc.mjs",
    "smoke:notification-ipc": "node scripts/smoke-notification-ipc.mjs",
    "smoke:webview-ipc": "node scripts/smoke-webview-ipc.mjs",
    "package": "node scripts/build-standalone.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
