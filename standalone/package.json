    "build:airdb": "node scripts/build-airdb.mjs",
    "prepare:extensions": "node scripts/prepare-extensions.mjs",
    "package": "node scripts/build-standalone.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
