{
  "name": "compat-extension",
  "publisher": "fixture",
  "version": "0.0.1",
  "main": "./extension.js",
  "activationEvents": ["*"],
  "contributes": {
    "commands": [
      {
        "command": "compat.fixture.run",
        "title": "Run Compatibility Fixture"
      },
      {
        "command": "compat.fixture.extra",
        "title": "Compatibility Fixture Extra"
      },
      {
        "command": "compat.fixture.editorLifecycle",
        "title": "Compatibility Fixture Editor Lifecycle"
      },
      {
        "command": "compat.fixture.editorLifecycleStatus",
        "title": "Compatibility Fixture Editor Lifecycle Status"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "compat.fixture.run",
          "when": "compat.fixture.ready"
        },
        {
          "command": "compat.fixture.extra",
          "when": "compat.fixture.mode == 'smoke'"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "airdbStandalone",
          "title": "Compat"
        }
      ]
    },
    "views": {
      "airdbStandalone": [
        {
          "id": "compat.webviewView",
          "name": "Compat Webview"
        }
      ]
    }
  }
}
